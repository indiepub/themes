---
import { Icon } from 'astro-icon/components';
import type { Author, IndiePubConfig } from '@indiepub/types';
import SocialIcon from './SocialIcon.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  author: Author;
  config: IndiePubConfig;
  activePath: string;
  topTags?: Array<{ name: string; slug: string; count: number }> | undefined;
  /** True when rendered inside the mobile overlay */
  mobile?: boolean | undefined;
}

const { author, activePath, topTags = [], mobile = false } = Astro.props;

const navLinks = [
  { href: '/',           label: 'All posts' },
  { href: '/notes',      label: 'Notes' },
  { href: '/articles',   label: 'Articles' },
  { href: '/photos',     label: 'Photos' },
  { href: '/bookmarks',  label: 'Bookmarks' },
];

function isActive(href: string): boolean {
  if (href === '/') return activePath === '/';
  return activePath === href || activePath.startsWith(href + '/');
}

const socialLinks = author.socialLinks ?? [];
const authorDomain = author.url ? new URL(author.url).hostname.replace(/^www\./, '') : undefined;
---

<div class:list={['side-profile', 'h-card', { 'side-profile--mobile': mobile }]}>
  <!-- Avatar -->
  {author.photo && (
    <a href="/about" class="side-profile__avatar-link">
      <img
        class="u-photo side-profile__avatar"
        src={author.photo}
        alt={author.name}
        width="72"
        height="72"
      />
    </a>
  )}

  <!-- Identity -->
  <div class="side-profile__identity">
    <a href="/about" class="p-name side-profile__name" rel="me">{author.name}</a>
    {authorDomain && (
      <span class="side-profile__domain text-sm text-secondary">{authorDomain}</span>
    )}
    {author.bio && (
      <p class="p-note side-profile__bio text-sm">{author.bio}</p>
    )}
  </div>

  <hr class="side-profile__divider" />

  <!-- Navigation -->
  <nav class="side-profile__nav" aria-label="Site navigation">
    {navLinks.map(link => (
      <a
        href={link.href}
        class:list={['side-profile__nav-link', { 'side-profile__nav-link--active': isActive(link.href) }]}
        aria-current={isActive(link.href) ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))}
  </nav>

  <hr class="side-profile__divider" />

  <!-- Subscribe -->
  <div class="side-profile__subscribe">
    <p class="side-profile__subscribe-label text-xs text-secondary">Subscribe</p>
    <div class="side-profile__feed-links">
      <a href="/feed.xml" class="side-profile__feed-link" title="RSS feed">
        <Icon name="lucide:rss" aria-hidden="true" />
        <span>RSS</span>
      </a>
      <a href="/feed.atom" class="side-profile__feed-link" title="Atom feed">
        <Icon name="lucide:rss" aria-hidden="true" />
        <span>Atom</span>
      </a>
      <a href="/feed.json" class="side-profile__feed-link" title="JSON Feed">
        <Icon name="lucide:rss" aria-hidden="true" />
        <span>JSON</span>
      </a>
    </div>
  </div>

  <!-- Tag cloud -->
  {topTags.length > 0 && (
    <div class="side-profile__tags">
      <p class="side-profile__section-label text-xs text-secondary">Topics</p>
      <div class="side-profile__tag-cloud">
        {topTags.map(tag => (
          <a
            href={`/tags/${encodeURIComponent(tag.slug)}`}
            class:list={['side-profile__tag', { 'side-profile__tag--active': activePath === `/tags/${tag.slug}` }]}
          >
            #{tag.name}
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Social links -->
  {socialLinks.length > 0 && (
    <div class="side-profile__social" aria-label="Social profiles">
      {socialLinks.map(link => (
        <a
          href={link.url}
          class="side-profile__social-link u-url"
          rel="me noopener"
          target="_blank"
          aria-label={link.label}
        >
          <SocialIcon icon={link.icon} aria-hidden="true" />
        </a>
      ))}
    </div>
  )}

  <!-- Theme toggle -->
  <div class="side-profile__theme">
    <ThemeToggle />
  </div>
</div>

<style>
  .side-profile {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .side-profile--mobile {
    /* no overrides needed */
  }

  /* Avatar */
  .side-profile__avatar-link {
    display: block;
    width: 4.5rem;
    text-decoration: none;
  }

  .side-profile__avatar {
    width: 4.5rem;
    height: 4.5rem;
    border-radius: var(--radius-full);
    object-fit: cover;
  }

  /* Identity */
  .side-profile__identity {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .side-profile__name {
    font-weight: var(--weight-bold);
    font-size: var(--text-base);
    color: var(--color-text-primary);
    text-decoration: none;
    line-height: var(--leading-snug);
  }

  .side-profile__name:hover {
    color: var(--color-text-link);
    text-decoration: none;
  }

  .side-profile__domain {
    display: block;
  }

  .side-profile__bio {
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Divider */
  .side-profile__divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0;
  }

  /* Navigation */
  .side-profile__nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .side-profile__nav-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition), background-color var(--transition);
  }

  .side-profile__nav-link:hover {
    color: var(--color-text-primary);
    background-color: var(--color-surface-2);
    text-decoration: none;
  }

  .side-profile__nav-link--active {
    color: var(--color-text-link);
    background-color: var(--color-brand-muted);
  }

  .side-profile__nav-link--active:hover {
    color: var(--color-text-link-hover);
    background-color: var(--color-brand-muted);
  }

  /* Subscribe */
  .side-profile__subscribe {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .side-profile__subscribe-label {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: var(--weight-semibold);
  }

  .side-profile__feed-links {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .side-profile__feed-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.2rem var(--space-2);
    border-radius: var(--radius-md);
    background-color: var(--color-surface-2);
    transition: color var(--transition), background-color var(--transition);
  }

  .side-profile__feed-link:hover {
    color: var(--color-text-link);
    background-color: var(--color-brand-muted);
    text-decoration: none;
  }

  .side-profile__feed-link svg {
    width: 0.75rem;
    height: 0.75rem;
    flex-shrink: 0;
  }

  /* Tag cloud */
  .side-profile__tags {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .side-profile__section-label {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: var(--weight-semibold);
  }

  .side-profile__tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .side-profile__tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.2em 0.5em;
    border-radius: var(--radius-full);
    transition: color var(--transition), background-color var(--transition);
  }

  .side-profile__tag:hover {
    color: var(--color-text-link);
    background-color: var(--color-brand-muted);
    text-decoration: none;
  }

  .side-profile__tag--active {
    color: var(--color-text-link);
    background-color: var(--color-brand-muted);
  }

  /* Social icons */
  .side-profile__social {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .side-profile__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition), background-color var(--transition);
  }

  .side-profile__social-link:hover {
    color: var(--color-text-primary);
    background-color: var(--color-surface-2);
    text-decoration: none;
  }

  .side-profile__social-link :global(svg) {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  /* Theme toggle */
  .side-profile__theme {
    margin-top: auto;
    padding-top: var(--space-2);
    align-self: flex-start;
  }
</style>
