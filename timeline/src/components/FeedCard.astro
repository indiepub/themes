---
import { Icon } from 'astro-icon/components';
import type { Entry, InteractionCounts } from '@indiepub/types';
import Markdown from '@indiepub/astro/components/Markdown.astro';
import PhotoCarousel from '@indiepub/astro/components/PhotoCarousel.astro';
import { formatDateCompact, isoDate, hostname, linkifyHashtags } from '../lib/format.ts';

interface Props {
  entry: Entry;
  counts?: InteractionCounts;
}

const { entry, counts } = Astro.props;
const hasInteractions = counts && (counts.likes > 0 || counts.reposts > 0 || counts.comments > 0);
const detailUrl = `/posts/${entry.slug}`;
const pubDate = entry.publishedAt ?? entry.createdAt;

function syndicationMeta(url: string): { icon: string; label: string } {
  try {
    const parsed = new URL(url);
    const host = parsed.hostname;
    const path = parsed.pathname;
    if (host === 'bsky.app' || host.endsWith('.bsky.app')) {
      return { icon: 'simple-icons:bluesky', label: 'Bluesky' };
    }
    if (host === 'twitter.com' || host === 'x.com') {
      return { icon: 'simple-icons:x', label: 'X' };
    }
    // Mastodon: path pattern /@username/<numeric-id>
    if (/\/@[^/]+\/\d+/.test(path)) {
      return { icon: 'simple-icons:mastodon', label: 'Mastodon' };
    }
  } catch {
    // ignore malformed URLs
  }
  return { icon: 'lucide:external-link', label: hostname(url) };
}

const typeBadgeLabel: Partial<Record<string, string>> = {
  article:  'article',
  photo:    'photo',
  bookmark: 'bookmark',
  reply:    'reply',
  like:     'like',
  repost:   'repost',
  video:    'video',
  checkin:  'checkin',
  rsvp:     'rsvp',
  event:    'event',
  watch:    'watched',
  read:     'read',
  listen:   'listened',
  play:     'played',
};

const showBadge = entry.type !== 'note';
const badgeLabel = typeBadgeLabel[entry.type];
---

<article
  class:list={['feed-card', 'h-entry', `feed-card--${entry.type}`]}
>
  {/* ── Note ──────────────────────────────────────────────── */}
  {entry.type === 'note' && (
    <div class="card-body">
      {(entry.visibility === 'members' || entry.visibility === 'paid') && (
        <div class="card-header">
          <span class="visibility-badge">
            <Icon name="lucide:lock" aria-hidden="true" />
            {entry.visibility === 'paid' ? 'Paid' : 'Members'}
          </span>
        </div>
      )}
      {entry.inReplyTo && (
        <p class="reply-pill">
          <Icon name="lucide:corner-down-right" aria-hidden="true" />
          <span class="text-secondary text-sm">in reply to </span>
          <a href={entry.inReplyTo} class="u-in-reply-to" rel="noopener" target="_blank">
            {hostname(entry.inReplyTo)}
          </a>
        </p>
      )}
      {entry.content && (
        <Markdown content={linkifyHashtags(entry.content)} class="e-content card-content" />
      )}
      {entry.attachments && entry.attachments.length > 0 && (
        <PhotoCarousel
          attachments={entry.attachments}
          fallbackAlt={entry.summary ?? ''}
          sizes="(min-width: 768px) 600px, 100vw"
          class="card-media"
        />
      )}
      <footer class="card-footer">
        <a href={detailUrl} class="card-footer__time u-url">
          <time class="dt-published" datetime={isoDate(pubDate)}>
            {formatDateCompact(pubDate)}
          </time>
        </a>
        {hasInteractions && (
          <div class="card-footer__counts">
            {counts!.likes > 0 && <span class="ix-count"><Icon name="lucide:heart" aria-hidden="true" />{counts!.likes}</span>}
            {counts!.reposts > 0 && <span class="ix-count"><Icon name="lucide:repeat-2" aria-hidden="true" />{counts!.reposts}</span>}
            {counts!.comments > 0 && <span class="ix-count"><Icon name="lucide:message-square" aria-hidden="true" />{counts!.comments}</span>}
          </div>
        )}
        <div class="card-footer__actions">
          {entry.syndicationUrls && entry.syndicationUrls.map((url: string) => {
            const { icon, label } = syndicationMeta(url);
            return (
              <a
                href={url}
                class="card-syndication u-syndication"
                rel="syndication noopener"
                target="_blank"
                aria-label={`${label} (syndicated copy)`}
              >
                <Icon name={icon} aria-hidden="true" />
              </a>
            );
          })}
        </div>
      </footer>
    </div>
  )}

  {/* ── Article ───────────────────────────────────────────── */}
  {entry.type === 'article' && (
    <div class="card-body">
      <div class="card-header">
        {showBadge && badgeLabel && <span class="type-badge">{badgeLabel}</span>}
        {(entry.visibility === 'members' || entry.visibility === 'paid') && (
          <span class="visibility-badge">
            <Icon name="lucide:lock" aria-hidden="true" />
            {entry.visibility === 'paid' ? 'Paid' : 'Members'}
          </span>
        )}
      </div>
      <h2 class="p-name article-title">
        <a href={detailUrl} class="u-url">{entry.name}</a>
      </h2>
      {entry.summary && (
        <p class="p-summary article-summary">{entry.summary}</p>
      )}
      {entry.tags && entry.tags.length > 0 && (
        <ul class="tag-list" aria-label="Tags">
          {entry.tags.map((tag: string) => (
            <li>
              <a href={`/tags/${encodeURIComponent(tag)}`} class="tag">#{tag}</a>
            </li>
          ))}
        </ul>
      )}
      <footer class="card-footer">
        <a href={detailUrl} class="card-footer__time u-url">
          <time class="dt-published" datetime={isoDate(pubDate)}>
            {formatDateCompact(pubDate)}
          </time>
        </a>
        {hasInteractions && (
          <div class="card-footer__counts">
            {counts!.likes > 0 && <span class="ix-count"><Icon name="lucide:heart" aria-hidden="true" />{counts!.likes}</span>}
            {counts!.reposts > 0 && <span class="ix-count"><Icon name="lucide:repeat-2" aria-hidden="true" />{counts!.reposts}</span>}
            {counts!.comments > 0 && <span class="ix-count"><Icon name="lucide:message-square" aria-hidden="true" />{counts!.comments}</span>}
          </div>
        )}
        <div class="card-footer__actions">
          {entry.syndicationUrls && entry.syndicationUrls.map((url: string) => {
            const { icon, label } = syndicationMeta(url);
            return (
              <a
                href={url}
                class="card-syndication u-syndication"
                rel="syndication noopener"
                target="_blank"
                aria-label={`${label} (syndicated copy)`}
              >
                <Icon name={icon} aria-hidden="true" />
              </a>
            );
          })}
          <a href={detailUrl} class="card-footer__read-link">
            Read article →
          </a>
        </div>
      </footer>
    </div>
  )}

  {/* ── Photo ─────────────────────────────────────────────── */}
  {entry.type === 'photo' && (entry.attachments?.length ?? 0) > 0 && (
    <div class="photo-card">
      <PhotoCarousel
        attachments={entry.attachments!}
        fallbackAlt={entry.summary ?? entry.name ?? ''}
        sizes="(min-width: 768px) 600px, 100vw"
        class="photo-card__media"
      />
      <div class="card-body">
        {(entry.summary || entry.content) && (
          <p class="p-summary photo-caption">
            {entry.summary ?? entry.content?.replace(/<[^>]*>/g, '').slice(0, 140)}
          </p>
        )}
        <footer class="card-footer">
          <a href={detailUrl} class="card-footer__time u-url">
            <time class="dt-published" datetime={isoDate(pubDate)}>
              {formatDateCompact(pubDate)}
            </time>
          </a>
          {showBadge && badgeLabel && (
            <span class="type-badge">{badgeLabel}</span>
          )}
          {hasInteractions && (
            <div class="card-footer__counts">
              {counts!.likes > 0 && <span class="ix-count"><Icon name="lucide:heart" aria-hidden="true" />{counts!.likes}</span>}
              {counts!.reposts > 0 && <span class="ix-count"><Icon name="lucide:repeat-2" aria-hidden="true" />{counts!.reposts}</span>}
              {counts!.comments > 0 && <span class="ix-count"><Icon name="lucide:message-square" aria-hidden="true" />{counts!.comments}</span>}
            </div>
          )}
          <div class="card-footer__actions">
            {entry.syndicationUrls && entry.syndicationUrls.map((url: string) => {
              const { icon, label } = syndicationMeta(url);
              return (
                <a
                  href={url}
                  class="card-syndication u-syndication"
                  rel="syndication noopener"
                  target="_blank"
                  aria-label={`${label} (syndicated copy)`}
                >
                  <Icon name={icon} aria-hidden="true" />
                </a>
              );
            })}
          </div>
        </footer>
      </div>
    </div>
  )}

  {/* ── Bookmark ──────────────────────────────────────────── */}
  {entry.type === 'bookmark' && entry.bookmarkOf && (
    <div class="card-body">
      <div class="card-header">
        {showBadge && badgeLabel && <span class="type-badge">{badgeLabel}</span>}
        {(entry.visibility === 'members' || entry.visibility === 'paid') && (
          <span class="visibility-badge">
            <Icon name="lucide:lock" aria-hidden="true" />
            {entry.visibility === 'paid' ? 'Paid' : 'Members'}
          </span>
        )}
        <span class="bookmark-domain text-sm text-secondary">
          <Icon name="lucide:bookmark" aria-hidden="true" />
          {hostname(entry.bookmarkOf)}
        </span>
      </div>
      <h2 class="p-name bookmark-title">
        <a href={entry.bookmarkOf} class="u-bookmark-of" rel="noopener" target="_blank">
          {entry.name ?? entry.bookmarkOf}
          <Icon name="lucide:external-link" aria-hidden="true" />
        </a>
      </h2>
      {entry.summary && (
        <p class="p-summary bookmark-desc">{entry.summary}</p>
      )}
      <footer class="card-footer">
        <a href={detailUrl} class="card-footer__time u-url">
          <time class="dt-published" datetime={isoDate(pubDate)}>
            {formatDateCompact(pubDate)}
          </time>
        </a>
        {hasInteractions && (
          <div class="card-footer__counts">
            {counts!.likes > 0 && <span class="ix-count"><Icon name="lucide:heart" aria-hidden="true" />{counts!.likes}</span>}
            {counts!.reposts > 0 && <span class="ix-count"><Icon name="lucide:repeat-2" aria-hidden="true" />{counts!.reposts}</span>}
            {counts!.comments > 0 && <span class="ix-count"><Icon name="lucide:message-square" aria-hidden="true" />{counts!.comments}</span>}
          </div>
        )}
        <div class="card-footer__actions">
          {entry.syndicationUrls && entry.syndicationUrls.map((url: string) => {
            const { icon, label } = syndicationMeta(url);
            return (
              <a
                href={url}
                class="card-syndication u-syndication"
                rel="syndication noopener"
                target="_blank"
                aria-label={`${label} (syndicated copy)`}
              >
                <Icon name={icon} aria-hidden="true" />
              </a>
            );
          })}
        </div>
      </footer>
    </div>
  )}

  {/* ── Verb entries (watch/read/listen/play) ──────────────── */}
  {['watch', 'read', 'listen', 'play'].includes(entry.type) && (
    <div class="card-body">
      <div class="card-header">
        {showBadge && badgeLabel && <span class="type-badge">{badgeLabel}</span>}
        {(entry.visibility === 'members' || entry.visibility === 'paid') && (
          <span class="visibility-badge">
            <Icon name="lucide:lock" aria-hidden="true" />
            {entry.visibility === 'paid' ? 'Paid' : 'Members'}
          </span>
        )}
      </div>
      <div class="verb-callout">
        <span class="verb-callout__emoji">
          {entry.type === 'watch' ? '📺' : entry.type === 'read' ? '📚' : entry.type === 'listen' ? '🎧' : '🎮'}
        </span>
        <span class="verb-callout__text">
          {entry.type === 'watch' ? 'Watched' : entry.type === 'read' ? 'Read' : entry.type === 'listen' ? 'Listened to' : 'Played'}
          {' '}
          {entry.objectUrl ? (
            <a href={entry.objectUrl} class="verb-callout__link" rel="noopener" target="_blank">
              {entry.objectName ?? entry.objectUrl}
              <Icon name="lucide:external-link" aria-hidden="true" />
            </a>
          ) : (
            <strong>{entry.objectName}</strong>
          )}
        </span>
      </div>
      {entry.rating != null && entry.rating > 0 && (
        <div class="verb-rating" aria-label={`Rating: ${entry.rating} out of 5`}>
          {[1,2,3,4,5].map(n => (
            <span class={n <= entry.rating! ? 'star-filled' : 'star-empty'}>{n <= entry.rating! ? '★' : '☆'}</span>
          ))}
        </div>
      )}
      {entry.content && (
        <Markdown content={linkifyHashtags(entry.content)} class="e-content card-content" />
      )}
      <footer class="card-footer">
        <a href={detailUrl} class="card-footer__time u-url">
          <time class="dt-published" datetime={isoDate(pubDate)}>
            {formatDateCompact(pubDate)}
          </time>
        </a>
        {hasInteractions && (
          <div class="card-footer__counts">
            {counts!.likes > 0 && <span class="ix-count"><Icon name="lucide:heart" aria-hidden="true" />{counts!.likes}</span>}
            {counts!.reposts > 0 && <span class="ix-count"><Icon name="lucide:repeat-2" aria-hidden="true" />{counts!.reposts}</span>}
            {counts!.comments > 0 && <span class="ix-count"><Icon name="lucide:message-square" aria-hidden="true" />{counts!.comments}</span>}
          </div>
        )}
        <div class="card-footer__actions">
          {entry.syndicationUrls && entry.syndicationUrls.map((url: string) => {
            const { icon, label } = syndicationMeta(url);
            return (
              <a
                href={url}
                class="card-syndication u-syndication"
                rel="syndication noopener"
                target="_blank"
                aria-label={`${label} (syndicated copy)`}
              >
                <Icon name={icon} aria-hidden="true" />
              </a>
            );
          })}
        </div>
      </footer>
    </div>
  )}

  {/* ── Like / Repost / Reply (compact) ───────────────────── */}
  {(entry.type === 'like' || entry.type === 'repost' || entry.type === 'reply') && (
    <div class="card-body interaction-card">
      <div class="card-header">
        {showBadge && badgeLabel && <span class="type-badge">{badgeLabel}</span>}
        {(entry.visibility === 'members' || entry.visibility === 'paid') && (
          <span class="visibility-badge">
            <Icon name="lucide:lock" aria-hidden="true" />
            {entry.visibility === 'paid' ? 'Paid' : 'Members'}
          </span>
        )}
        <span class="interaction-verb text-sm text-secondary">
          {entry.type === 'like'   ? 'liked'
          : entry.type === 'repost' ? 'reposted'
          : 'replied to'}
        </span>
      </div>
      {(entry.likeOf ?? entry.repostOf ?? entry.inReplyTo) && (
        <blockquote class="interaction-target">
          <a
            href={entry.likeOf ?? entry.repostOf ?? entry.inReplyTo ?? '#'}
            class:list={[
              entry.likeOf    ? 'u-like-of'    : '',
              entry.repostOf  ? 'u-repost-of'  : '',
              entry.inReplyTo ? 'u-in-reply-to' : '',
            ]}
            rel="noopener"
            target="_blank"
          >
            <span class="interaction-target__host">
              {hostname(entry.likeOf ?? entry.repostOf ?? entry.inReplyTo ?? '')}
            </span>
          </a>
        </blockquote>
      )}
      {entry.content && entry.type === 'reply' && (
        <Markdown content={linkifyHashtags(entry.content)} class="e-content card-content" />
      )}
      <footer class="card-footer">
        <a href={detailUrl} class="card-footer__time u-url">
          <time class="dt-published" datetime={isoDate(pubDate)}>
            {formatDateCompact(pubDate)}
          </time>
        </a>
      </footer>
    </div>
  )}
</article>

<style>
  .feed-card {
    background-color: var(--color-surface-1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: background-color var(--transition);
  }

  .feed-card:hover {
    background-color: var(--color-surface-2);
  }

  /* ── Card body ─────────────────────────────────────────── */
  .card-body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  /* ── Type badge ─────────────────────────────────────────── */
  .type-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-link);
    background-color: var(--color-brand-muted);
    padding: 0.15em 0.5em;
    border-radius: var(--radius-full);
  }

  .visibility-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-warning, #b58a00);
    background-color: color-mix(in oklch, var(--color-warning, #b58a00) 12%, transparent);
    padding: 0.15em 0.5em;
    border-radius: var(--radius-full);
  }

  .visibility-badge :global(svg) {
    width: 0.7em;
    height: 0.7em;
  }

  /* ── Reply pill ─────────────────────────────────────────── */
  .reply-pill {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
  }

  .reply-pill svg {
    width: 0.875rem;
    height: 0.875rem;
    color: var(--color-text-tertiary);
    flex-shrink: 0;
  }

  /* ── Media ───────────────────────────────────────────────── */
  .card-media {
    border-radius: var(--radius-md);
    max-height: 360px;
    object-fit: cover;
  }

  /* ── Footer ──────────────────────────────────────────────── */
  .card-footer {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .card-footer__time {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    text-decoration: none;
    flex-shrink: 0;
  }

  .card-footer__time:hover {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .card-footer__counts {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .ix-count {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .ix-count :global(svg) {
    width: 0.875rem;
    height: 0.875rem;
  }

  .card-footer__actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-left: auto;
    flex-wrap: wrap;
  }

  .card-footer__read-link {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-link);
    text-decoration: none;
  }

  .card-footer__read-link:hover {
    text-decoration: underline;
  }

  /* ── Syndication icons ──────────────────────────────────── */
  .card-syndication {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color var(--transition);
  }

  .card-syndication:hover {
    color: var(--color-text-link);
    text-decoration: none;
  }

  .card-syndication :global(svg) {
    width: 1rem;
    height: 1rem;
  }

  /* ── Article card ────────────────────────────────────────── */
  .article-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-snug);
  }

  .article-title a {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .article-title a:hover {
    color: var(--color-text-link);
    text-decoration: none;
  }

  .article-summary {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Tag list ────────────────────────────────────────────── */
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
  }

  .tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-link);
    background-color: var(--color-brand-muted);
    padding: 0.2em 0.6em;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: background-color var(--transition);
  }

  .tag:hover {
    background-color: var(--color-surface-3);
    text-decoration: none;
  }

  /* ── Photo card ──────────────────────────────────────────── */
  .photo-card {
    display: flex;
    flex-direction: column;
  }

  .photo-card__media {
    max-height: 400px;
    object-fit: cover;
    width: 100%;
  }

  .photo-caption {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Bookmark card ───────────────────────────────────────── */
  .bookmark-domain {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }

  .bookmark-domain svg {
    width: 0.75rem;
    height: 0.75rem;
    flex-shrink: 0;
  }

  .bookmark-title {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
  }

  .bookmark-title a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .bookmark-title a:hover {
    color: var(--color-text-link);
    text-decoration: none;
  }

  .bookmark-title svg {
    width: 0.75rem;
    height: 0.75rem;
    flex-shrink: 0;
    color: var(--color-text-tertiary);
  }

  .bookmark-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* ── Verb callout ───────────────────────────────────────── */
  .verb-callout {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3);
    background-color: var(--color-surface-2);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    line-height: var(--leading-snug);
  }

  .verb-callout__emoji {
    font-size: var(--text-xl);
    flex-shrink: 0;
  }

