---
import type { Entry } from '@indiepub/types';
import Markdown from '@indiepub/astro/components/Markdown';
import PhotoCarousel from '@indiepub/astro/components/PhotoCarousel';
import TagList from './TagList.astro';
import { formatDateCompact, isoDate } from '../lib/format.ts';

interface Props {
  entry: Entry;
}

const { entry } = Astro.props;
const detailUrl = `/posts/${entry.slug}`;
const pubDate = entry.publishedAt ?? entry.createdAt;
---

<div class="photo-card">
  <PhotoCarousel
    attachments={entry.attachments!}
    fallbackAlt={entry.summary ?? entry.name ?? ''}
    sizes="(min-width: 640px) 50vw, 100vw"
  />
  <div class="photo-card__body">
    {entry.summary ? (
      <p class="p-summary photo-card__summary">{entry.summary}</p>
    ) : entry.content ? (
      <Markdown content={entry.content} class="e-content photo-card__content-preview" />
    ) : null}
    <div class="photo-card__meta">
      <TagList tags={entry.tags} />
      <a href={detailUrl} class="u-url photo-card__permalink">
        <time class="dt-published" datetime={isoDate(pubDate)}>
          {formatDateCompact(pubDate)}
        </time>
      </a>
    </div>
  </div>
</div>

<style>
  .photo-card {
    display: flex;
    flex-direction: column;
  }

  .photo-card__body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .photo-card__summary {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .photo-card__content-preview {
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    line-height: var(--leading-relaxed);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
  }

  .photo-card__content-preview :global(p) { margin: 0; }
  .photo-card__content-preview :global(p + p) { margin-top: 0.4em; }
  .photo-card__content-preview :global(blockquote) {
    margin: 0.4em 0;
    padding-left: var(--space-3);
    border-left: 2px solid var(--color-border);
    color: var(--color-text-secondary);
  }
  .photo-card__content-preview :global(a) { color: var(--color-text-link); }

  .photo-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .photo-card__permalink {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    text-decoration: none;
    flex-shrink: 0;
  }

  .photo-card__permalink:hover {
    color: var(--color-text-link);
  }
</style>
