---
import { Icon } from 'astro-icon/components';
import type { Entry, Interaction, InteractionCounts, WebMention } from '@indiepub/types';
import Markdown from '@indiepub/astro/components/Markdown.astro';
import PhotoCarousel from '@indiepub/astro/components/PhotoCarousel.astro';
import TagList from './TagList.astro';
import HCard from './HCard.astro';
import { formatDate, isoDate, hostname } from '../lib/format.ts';

interface Props {
  entry: Entry;
  webmentions: WebMention[];
  interactions: Interaction[];
  counts: InteractionCounts;
}

const { entry, webmentions, interactions, counts } = Astro.props;

// Merge interactions and webmentions into unified response items
type ResponseItem = {
  type: 'like' | 'repost' | 'comment';
  authorName?: string;
  authorUrl?: string;
  authorPhoto?: string;
  content?: string;
  sourceUrl: string;
  sourceLabel: string;
};

const responses: ResponseItem[] = [];

for (const ix of interactions) {
  if (ix.type !== 'like' && ix.type !== 'repost' && ix.type !== 'comment') continue;
  responses.push({
    type: ix.type,
    authorName: ix.authorName,
    authorUrl: ix.authorUrl,
    authorPhoto: ix.authorPhoto,
    content: ix.content,
    sourceUrl: ix.externalUrl ?? ix.authorUrl ?? '#',
    sourceLabel: ix.source === 'bluesky' ? 'Bluesky' : ix.source === 'mastodon' ? 'Mastodon' : ix.source,
  });
}

for (const wm of webmentions) {
  const wmType = wm.type === 'reply' || wm.type === 'mention' ? 'comment' : wm.type === 'like' ? 'like' : wm.type === 'repost' ? 'repost' : null;
  if (!wmType) continue;
  responses.push({
    type: wmType,
    authorName: wm.authorName,
    authorUrl: wm.authorUrl,
    authorPhoto: wm.authorPhoto,
    content: wm.content,
    sourceUrl: wm.source,
    sourceLabel: hostname(wm.source),
  });
}

const responseLikes = responses.filter(r => r.type === 'like');
const responseReposts = responses.filter(r => r.type === 'repost');
const responseComments = responses.filter(r => r.type === 'comment');
const hasResponses = responses.length > 0;
const pubDate = entry.publishedAt ?? entry.createdAt;
const config = Astro.locals.indiepub?.config;

const attachments = entry.attachments?.length
  ? entry.attachments
  : entry.photo
    ? [{ id: '', url: entry.photo, contentType: 'image/*', displayOrder: 0 }]
    : [];
---

<article class="entry-detail h-entry">
  <header class="entry-detail__header">
    {entry.name && (
      <h1 class="p-name entry-detail__title">{entry.name}</h1>
    )}
    <div class="entry-detail__meta">
      <a href={`/posts/${entry.slug}`} class="u-url entry-detail__permalink">
        <time class="dt-published" datetime={isoDate(pubDate)}>
          {formatDate(pubDate)}
        </time>
      </a>
      {entry.updatedAt && entry.updatedAt > pubDate && (
        <span class="entry-detail__updated text-sm text-secondary">
          Updated <time class="dt-updated" datetime={isoDate(entry.updatedAt)}>{formatDate(entry.updatedAt)}</time>
        </span>
      )}
    </div>

    {entry.inReplyTo && (
      <p class="entry-detail__reply-to">
        <Icon name="lucide:corner-down-right" aria-hidden="true" />
        <span>in reply to </span>
        <a href={entry.inReplyTo} class="u-in-reply-to" rel="noopener" target="_blank">{hostname(entry.inReplyTo)}</a>
      </p>
    )}
  </header>

  {attachments.length > 0 && (
    <PhotoCarousel
      attachments={attachments}
      fallbackAlt={entry.summary ?? entry.name ?? ''}
      sizes="(min-width: 768px) 65ch, 100vw"
      class="entry-detail__media"
    />
  )}

  {entry.content && (
    <Markdown content={entry.content} class="e-content entry-detail__content prose" />
  )}

  <footer class="entry-detail__footer">
    <TagList tags={entry.tags} />

    {entry.syndicationUrls && entry.syndicationUrls.length > 0 && (
      <div class="entry-detail__syndication">
        <p class="text-sm text-secondary">Syndicated to:</p>
        <ul>
          {entry.syndicationUrls.map((url: string) => (
            <li>
              <a href={url} class="u-syndication" rel="syndication noopener" target="_blank">
                {hostname(url)}
                <Icon name="lucide:external-link" aria-hidden="true" />
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {(counts.likes > 0 || counts.comments > 0 || counts.reposts > 0) && (
      <div class="entry-detail__counts">
        {counts.likes > 0 && (
          <span class="interaction-count">
            <Icon name="lucide:heart" aria-hidden="true" />
            {counts.likes} {counts.likes === 1 ? 'like' : 'likes'}
          </span>
        )}
        {counts.reposts > 0 && (
          <span class="interaction-count">
            <Icon name="lucide:repeat-2" aria-hidden="true" />
            {counts.reposts} {counts.reposts === 1 ? 'repost' : 'reposts'}
          </span>
        )}
        {counts.comments > 0 && (
          <span class="interaction-count">
            <Icon name="lucide:message-square" aria-hidden="true" />
            {counts.comments} {counts.comments === 1 ? 'comment' : 'comments'}
          </span>
        )}
      </div>
    )}

    {entry.author && (
      <div class="entry-detail__author">
        <HCard author={entry.author} config={config} variant="compact" />
      </div>
    )}
  </footer>
</article>

{hasResponses && (
  <section class="responses" aria-labelledby="responses-heading">
    <h2 id="responses-heading" class="responses__heading">
      Responses <span class="responses__count">({responses.length})</span>
    </h2>

    {responseLikes.length > 0 && (
      <div class="responses__pile" aria-label={`${responseLikes.length} ${responseLikes.length === 1 ? 'like' : 'likes'}`}>
        <p class="responses__pile-label text-sm text-secondary">
          <Icon name="lucide:heart" aria-hidden="true" />
          {responseLikes.length} {responseLikes.length === 1 ? 'like' : 'likes'}
        </p>
        <div class="responses__avatars">
          {responseLikes.slice(0, 12).map(r => (
            r.authorPhoto ? (
              <a href={r.authorUrl ?? r.sourceUrl} rel="noopener" target="_blank" title={r.authorName ?? undefined}>
                <img class="responses__avatar" src={r.authorPhoto} alt={r.authorName ?? ''} width="32" height="32" />
              </a>
            ) : (
              <a href={r.authorUrl ?? r.sourceUrl} rel="noopener" target="_blank" title={r.authorName ?? undefined}
                 class="responses__avatar responses__avatar--placeholder">
                <Icon name="lucide:user" aria-hidden="true" />
              </a>
            )
          ))}
          {responseLikes.length > 12 && (
            <span class="responses__overflow">+{responseLikes.length - 12}</span>
          )}
        </div>
      </div>
    )}

    {responseReposts.length > 0 && (
      <div class="responses__pile" aria-label={`${responseReposts.length} ${responseReposts.length === 1 ? 'repost' : 'reposts'}`}>
        <p class="responses__pile-label text-sm text-secondary">
          <Icon name="lucide:repeat-2" aria-hidden="true" />
          {responseReposts.length} {responseReposts.length === 1 ? 'repost' : 'reposts'}
        </p>
        <div class="responses__avatars">
          {responseReposts.slice(0, 12).map(r => (
            r.authorPhoto ? (
              <a href={r.authorUrl ?? r.sourceUrl} rel="noopener" target="_blank" title={r.authorName ?? undefined}>
                <img class="responses__avatar" src={r.authorPhoto} alt={r.authorName ?? ''} width="32" height="32" />
              </a>
            ) : (
              <a href={r.authorUrl ?? r.sourceUrl} rel="noopener" target="_blank" title={r.authorName ?? undefined}
                 class="responses__avatar responses__avatar--placeholder">
                <Icon name="lucide:user" aria-hidden="true" />
              </a>
            )
          ))}
          {responseReposts.length > 12 && (
            <span class="responses__overflow">+{responseReposts.length - 12}</span>
          )}
        </div>
      </div>
    )}

    {responseComments.length > 0 && (
      <div class="responses__comments">
        <p class="responses__comments-label text-sm text-secondary">
          <Icon name="lucide:message-square" aria-hidden="true" />
          {responseComments.length} {responseComments.length === 1 ? 'reply' : 'replies'}
        </p>
        <ul class="responses__comment-list">
          {responseComments.map(r => (
            <li class="response-comment">
              {r.authorPhoto && (
                <img class="response-comment__photo" src={r.authorPhoto} alt={r.authorName ?? ''} width="32" height="32" />
              )}
              <div class="response-comment__body">
                <a href={r.authorUrl ?? r.sourceUrl} class="response-comment__author" rel="noopener" target="_blank">
                  {r.authorName ?? r.sourceLabel}
                </a>
                {r.content && (
                  <p class="response-comment__content">{r.content}</p>
                )}
                <a href={r.sourceUrl} class="response-comment__source text-xs text-secondary" rel="noopener" target="_blank">
                  {r.sourceLabel}
                </a>
              </div>
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>
)}

<style>
  .entry-detail {
    max-width: var(--max-width-content);
  }

  .entry-detail__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .entry-detail__title {
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
  }

  .entry-detail__meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .entry-detail__permalink {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    text-decoration: none;
  }

  .entry-detail__permalink:hover {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .entry-detail__reply-to {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .entry-detail__reply-to svg {
    width: 0.875rem;
    height: 0.875rem;
    color: var(--color-text-tertiary);
    flex-shrink: 0;
  }

  .entry-detail__media {
    margin-bottom: var(--space-6);
    border-radius: var(--radius-lg);
  }

  .entry-detail__footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .entry-detail__syndication ul {
    list-style: none;
    padding: 0;
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .entry-detail__syndication a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
  }

  .entry-detail__syndication svg {
    width: 0.75rem;
    height: 0.75rem;
  }

  .entry-detail__counts {
    display: flex;
    gap: var(--space-4);
  }

  .interaction-count {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .interaction-count svg {
    width: 1rem;
    height: 1rem;
  }

  /* Responses */
  .responses {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .responses__heading {
    font-size: var(--text-lg);
  }

  .responses__count {
    font-weight: var(--weight-normal);
    color: var(--color-text-secondary);
  }

  .responses__pile {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .responses__pile-label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .responses__pile-label svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .responses__avatars {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    align-items: center;
  }

  .responses__avatar {
    display: block;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-full);
    object-fit: cover;
    border: 2px solid var(--color-bg);
    margin-left: -0.375rem;
    transition: transform var(--transition);
  }

  .responses__avatars a:first-child .responses__avatar,
  .responses__avatars a:first-child {
    margin-left: 0;
  }

  .responses__avatar:hover {
    transform: translateY(-2px);
    z-index: 1;
    position: relative;
  }

  .responses__avatar--placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-surface-2, var(--color-surface));
    color: var(--color-text-tertiary);
    text-decoration: none;
  }

  .responses__avatar--placeholder :global(svg) {
    width: 1rem;
    height: 1rem;
  }

  .responses__overflow {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    margin-left: var(--space-2);
  }

  .responses__comments {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .responses__comments-label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .responses__comments-label svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .responses__comment-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .response-comment {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .response-comment__photo {
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-full);
    object-fit: cover;
    flex-shrink: 0;
  }

  .response-comment__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }

  .response-comment__author {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .response-comment__author:hover { color: var(--color-text-link); }

  .response-comment__content {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .response-comment__source {
    text-decoration: none;
  }

  .response-comment__source:hover { color: var(--color-text-link) !important; }
</style>
