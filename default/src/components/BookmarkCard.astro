---
import { Icon } from 'astro-icon/components';
import type { Entry, InteractionCounts } from '@indiepub/types';
import InteractionBar from './InteractionBar.astro';
import { formatDateCompact, isoDate, hostname } from '../lib/format.ts';

interface Props {
  entry: Entry;
  counts?: InteractionCounts;
}

const { entry, counts } = Astro.props;
const pubDate = entry.publishedAt ?? entry.createdAt;
---

<div class="bookmark-card">
  <h2 class="p-name bookmark-card__title">
    <a href={entry.bookmarkOf!} class="u-bookmark-of" rel="noopener" target="_blank">
      {entry.name ?? entry.bookmarkOf}
      <Icon name="lucide:external-link" aria-hidden="true" />
    </a>
  </h2>
  <p class="bookmark-card__source text-sm text-secondary">{hostname(entry.bookmarkOf!)}</p>
  {entry.summary && <p class="p-summary bookmark-card__desc">{entry.summary}</p>}
  <div class="bookmark-card__meta">
    <time class="dt-published bookmark-card__date" datetime={isoDate(pubDate)}>
      {formatDateCompact(pubDate)}
    </time>
    {counts && <InteractionBar counts={counts} />}
  </div>
</div>

<style>
  .bookmark-card {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .bookmark-card__title {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
  }

  .bookmark-card__title a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .bookmark-card__title a:hover {
    color: var(--color-text-link);
  }

  .bookmark-card__title svg {
    width: 0.75rem;
    height: 0.75rem;
    flex-shrink: 0;
    color: var(--color-text-tertiary);
  }

  .bookmark-card__desc {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .bookmark-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .bookmark-card__date {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }
</style>
