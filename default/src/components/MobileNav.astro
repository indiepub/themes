---
interface NavItem {
  href: string;
  label: string;
}

interface Props {
  nav: NavItem[];
  currentPath: string;
}

const { nav, currentPath } = Astro.props;
---

<nav id="mobile-nav" class="site-mobile-nav" aria-hidden="true" aria-label="Mobile navigation">
  <ul>
    {nav.map(({ href, label }) => (
      <li>
        <a
          href={href}
          aria-current={currentPath.startsWith(href) ? 'page' : undefined}
        >
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .site-mobile-nav {
    display: none;
    border-top: 1px solid var(--color-border);
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-surface-1);
  }

  .site-mobile-nav[aria-hidden="false"] {
    display: block;
  }

  .site-mobile-nav ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .site-mobile-nav a {
    display: block;
    padding: var(--space-3);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    font-weight: var(--weight-medium);
    text-decoration: none;
  }

  .site-mobile-nav a:hover,
  .site-mobile-nav a[aria-current="page"] {
    background-color: var(--color-brand-muted);
    color: var(--color-text-link);
    text-decoration: none;
  }
</style>
