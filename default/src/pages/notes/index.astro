---
import Page from '../../layouts/Page.astro';
import EntryCard from '../../components/EntryCard.astro';
import NoteComposer from '../../components/NoteComposer.astro';

if (!Astro.locals.indiepub) {
  return new Response('Service unavailable', { status: 503 });
}

const memberTier = Astro.locals.member?.tier ?? null;
const notes = await Astro.locals.indiepub.content.getEntries('note', { memberTier, limit: 30 });

Astro.response.headers.set(
  'Cache-Control',
  Astro.locals.isAdmin ? 'no-store' : 'public, s-maxage=60, stale-while-revalidate=3600',
);
---

<Page title="Notes">
  <div class="page-header">
    <h1>Notes</h1>
    <p class="text-secondary">Short posts, thoughts, and replies.</p>
  </div>

  <NoteComposer />

  {notes.length > 0 ? (
    <div class="h-feed entry-feed" aria-label="Notes feed">
      {notes.map(entry => (
        <EntryCard entry={entry} />
      ))}
    </div>
  ) : (
    <p class="text-secondary">No notes yet.</p>
  )}
</Page>

<style>
  .page-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .entry-feed {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
</style>
