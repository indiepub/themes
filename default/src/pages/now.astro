---
import Page from '../layouts/Page.astro';
import EntryDetail from '../components/EntryDetail.astro';
import { formatDate } from '../lib/format.ts';

let nowEntry = null;
let interactions = { likes: 0, comments: 0, reposts: 0 };
let webmentions: import('@indiepub/types').WebMention[] = [];

if (Astro.locals.indiepub) {
  const { content } = Astro.locals.indiepub;
  const entries = await content.getEntries('note', { tag: 'now', limit: 1 });
  nowEntry = entries[0] ?? null;

  if (nowEntry) {
    [interactions, webmentions] = await Promise.all([
      content.getInteractionCounts(nowEntry.id),
      content.getWebmentions(nowEntry.id),
    ]);
  }
}

Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=3600');
---

<Page title="Now">
  <div class="page-header">
    <h1>Now</h1>
    {nowEntry && (
      <p class="text-sm text-secondary">
        Last updated {formatDate(nowEntry.publishedAt ?? nowEntry.createdAt)}
      </p>
    )}
  </div>

  {nowEntry ? (
    <EntryDetail entry={nowEntry} webmentions={webmentions} interactions={interactions} />
  ) : (
    <div class="now-placeholder">
      <p>
        This is a <a href="https://nownownow.com/about" rel="noopener" target="_blank">/now page</a> —
        a snapshot of what's happening in the site owner's life right now.
      </p>
      <p>
        To update this page, publish a note and tag it with <strong>#now</strong>.
        The most recent <code>now</code>-tagged note will appear here automatically.
      </p>
    </div>
  )}
</Page>

<style>
  .page-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .now-placeholder {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-8);
    background-color: var(--color-surface-1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    max-width: var(--max-width-content);
  }
</style>
