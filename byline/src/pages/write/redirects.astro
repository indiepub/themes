---
import Page from '../../layouts/Page.astro';
import { createDb } from '@indiepub/astro/lib/db';
import { redirects } from '@indiepub/db/schema';
import type { DbRedirect } from '@indiepub/db';
import { eq, asc } from 'drizzle-orm';
import { nanoid } from 'nanoid';
import type { D1Database } from '@cloudflare/workers-types';

if (!Astro.locals.isAdmin) return Astro.redirect('/');

const indiepub = Astro.locals.indiepub;
if (!indiepub) return new Response('Service unavailable', { status: 503 });

const d1BindingName = indiepub.config.d1BindingName ?? 'DB';
const runtime = (Astro.locals as unknown as Record<string, unknown>)['runtime'] as
  | { env: Record<string, unknown> }
  | undefined;
const d1 = runtime?.env?.[d1BindingName] as D1Database;
const db = createDb(d1);

let error: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action');

  if (action === 'delete') {
    const id = String(form.get('id') ?? '');
    if (id) await db.delete(redirects).where(eq(redirects.id, id));
    return Astro.redirect('/write/redirects');
  } else {
    const fromRaw = String(form.get('fromPath') ?? '').trim();
    const toPath  = String(form.get('toPath')   ?? '').trim();
    const status  = Number(form.get('status') ?? 301) as 301 | 302;

    if (!fromRaw.startsWith('/')) {
      error = 'From path must start with /';
    } else if (!toPath) {
      error = 'To path is required';
    } else {
      const fromPath = fromRaw.replace(/\/+$/, '') || '/';
      if (fromPath === toPath) {
        error = 'From and To paths must be different';
      } else {
        await db
          .insert(redirects)
          .values({ id: nanoid(), fromPath, toPath, status, createdAt: new Date() })
          .onConflictDoUpdate({
            target: redirects.fromPath,
            set: { toPath, status },
          });
        return Astro.redirect('/write/redirects');
      }
    }
  }
}

const rows: DbRedirect[] = await db.select().from(redirects).orderBy(asc(redirects.createdAt));

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<Page title="Redirects">
  <div class="redirects-page">
    <header>
      <div>
        <a href="/write" class="back-link">← Write</a>
        <h1>Redirects</h1>
      </div>
    </header>

    <div class="add-card">
      <h2>Add redirect</h2>
      {error && <p class="form-error">{error}</p>}
      <form method="post" class="add-form">
        <div class="field">
          <label>From path</label>
          <input name="fromPath" placeholder="/old-path" required />
        </div>
        <div class="field">
          <label>To path or URL</label>
          <input name="toPath" placeholder="/new-path or https://..." required />
        </div>
        <div class="field field--narrow">
          <label>Type</label>
          <select name="status">
            <option value="301">301 Permanent</option>
            <option value="302">302 Temporary</option>
          </select>
        </div>
        <button type="submit" class="btn-add">Add</button>
      </form>
    </div>

    {rows.length === 0 ? (
      <p class="empty">No redirects yet.</p>
    ) : (
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>From</th>
              <th>To</th>
              <th>Type</th>
              <th>Date</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {rows.map(r => (
              <tr>
                <td><code>{r.fromPath}</code></td>
                <td class="to-cell">{r.toPath}</td>
                <td>
                  <span class={`pill pill-${r.status === 301 ? 'perm' : 'temp'}`}>
                    {r.status === 301 ? '301' : '302'}
                  </span>
                </td>
                <td class="date">{formatDate(r.createdAt)}</td>
                <td>
                  <form method="post">
                    <input type="hidden" name="_action" value="delete" />
                    <input type="hidden" name="id" value={r.id} />
                    <button type="submit" class="btn-delete">Delete</button>
                  </form>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</Page>

<style>
  .redirects-page {
    max-width: 52rem;
    margin-inline: auto;
  }

  .back-link {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    text-decoration: none;
    display: block;
    margin-bottom: var(--space-2);
  }

  .back-link:hover {
    color: var(--color-text-link);
  }

  header {
    margin-bottom: var(--space-8);
  }

  h1 {
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    letter-spacing: -0.02em;
  }

  /* ── Add card ── */
  .add-card {
    padding: var(--space-6);
    background-color: var(--color-surface-1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-8);
  }

  .add-card h2 {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-4);
  }

  .form-error {
    color: oklch(45% 0.18 25);
    font-size: var(--text-sm);
    margin-bottom: var(--space-3);
  }

  .add-form {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: flex-end;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    flex: 1;
    min-width: 10rem;
  }

  .field--narrow {
    flex: 0 0 auto;
    min-width: 9rem;
  }

  .field label {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .field input,
  .field select {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    background-color: var(--color-surface);
    color: var(--color-text-primary);
    width: 100%;
  }

  .field input:focus,
  .field select:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
    border-color: var(--color-accent);
  }

  .btn-add {
    padding: var(--space-2) var(--space-5);
    background-color: var(--color-accent);
    color: var(--color-text-on-accent);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    white-space: nowrap;
    align-self: flex-end;
  }

  .btn-add:hover {
    background-color: var(--color-accent-hover);
  }

  /* ── Table ── */
  .table-wrap {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  thead th {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--color-border);
  }

  tbody tr {
    border-bottom: 1px solid var(--color-border);
  }

  tbody tr:last-child {
    border-bottom: none;
  }

  tbody td {
    padding: var(--space-3) var(--space-4);
    vertical-align: middle;
  }

  code {
    font-size: 0.85em;
    color: var(--color-text-primary);
  }

  .to-cell {
    color: var(--color-text-secondary);
    max-width: 20rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .date {
    color: var(--color-text-tertiary);
    white-space: nowrap;
  }

  /* ── Pills ── */
  .pill {
    display: inline-block;
    padding: 0.15em var(--space-2);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    white-space: nowrap;
  }

  .pill-perm {
    background-color: oklch(90% 0.04 145);
    color: oklch(30% 0.10 145);
  }

  .pill-temp {
    background-color: oklch(90% 0.03 250);
    color: oklch(30% 0.08 250);
  }

  /* ── Delete ── */
  .btn-delete {
    background: none;
    border: none;
    cursor: pointer;
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .btn-delete:hover {
    color: oklch(45% 0.18 25);
    background-color: oklch(95% 0.02 25);
  }

  .empty {
    color: var(--color-text-tertiary);
    font-style: italic;
    padding: var(--space-8) 0;
    text-align: center;
  }
</style>
