---
import Page from '../../layouts/Page.astro';
import { createDb } from '@indiepub/astro/lib/db';
import { entries } from '@indiepub/db/schema';
import { and, desc, inArray, count } from 'drizzle-orm';
import type { D1Database } from '@cloudflare/workers-types';

if (!Astro.locals.isAdmin) return Astro.redirect('/');

const indiepub = Astro.locals.indiepub;
if (!indiepub) return new Response('Service unavailable', { status: 503 });

const cfg = indiepub.config;
const d1BindingName = cfg.d1BindingName ?? 'DB';
const runtime = (Astro.locals as unknown as Record<string, unknown>)['runtime'] as
  | { env: Record<string, unknown> }
  | undefined;
const d1 = runtime?.env?.[d1BindingName] as D1Database;

const db = createDb(d1);

const WRITER_TYPES = ['article', 'note'] as const;

const [subscriberCount, statusCounts, recentRows] = await Promise.all([
  indiepub.content.getSubscriberCount(),

  db
    .select({ status: entries.status, total: count() })
    .from(entries)
    .where(inArray(entries.type, WRITER_TYPES as unknown as string[]))
    .groupBy(entries.status),

  db
    .select({
      id: entries.id,
      type: entries.type,
      name: entries.name,
      content: entries.content,
      status: entries.status,
      publishedAt: entries.publishedAt,
      createdAt: entries.createdAt,
    })
    .from(entries)
    .where(
      and(
        inArray(entries.type, WRITER_TYPES as unknown as string[]),
        inArray(entries.status, ['draft', 'published']),
      ),
    )
    .orderBy(
      // drafts first (draft < published alphabetically), then newest
      entries.status,
      desc(entries.publishedAt),
      desc(entries.createdAt),
    )
    .limit(10),
]);

let publishedCount = 0;
let draftCount = 0;
for (const row of statusCounts) {
  if (row.status === 'published') publishedCount = row.total;
  else if (row.status === 'draft') draftCount = row.total;
}

function formatDate(d: Date | null | undefined) {
  if (!d) return '—';
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function truncate(s: string | null | undefined, len = 80) {
  if (!s) return '';
  return s.length > len ? s.slice(0, len).trimEnd() + '…' : s;
}
---

<Page title="Write">
  <div class="write-dash">
    <header>
      <h1>Write</h1>
      <div class="actions">
        <form method="post" action="/write/new">
          <input type="hidden" name="type" value="article" />
          <button type="submit" class="btn-new">New article</button>
        </form>
        <form method="post" action="/write/new">
          <input type="hidden" name="type" value="note" />
          <button type="submit" class="btn-new btn-new--ghost">New note</button>
        </form>
      </div>
    </header>

    <!-- Stats row -->
    <div class="stats">
      <div class="stat">
        <span class="stat-value">{subscriberCount}</span>
        <span class="stat-label">subscribers</span>
      </div>
      <div class="stat">
        <span class="stat-value">{publishedCount}</span>
        <span class="stat-label">published</span>
      </div>
      <div class="stat">
        <span class="stat-value">{draftCount}</span>
        <span class="stat-label">drafts</span>
      </div>
      <a href="/write/redirects" class="stats-tool-link">Redirects →</a>
    </div>

    <!-- Recent posts -->
    {recentRows.length > 0 ? (
      <table>
        <thead>
          <tr>
            <th>Post</th>
            <th>Type</th>
            <th>Status</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          {recentRows.map(row => (
            <tr>
              <td>
                <a href={`/write/${row.id}`}>
                  {row.name
                    ? row.name
                    : <span class="preview">{truncate(row.content) || '(empty)'}</span>
                  }
                </a>
              </td>
              <td><span class={`pill pill-${row.type}`}>{row.type}</span></td>
              <td><span class={`pill pill-${row.status}`}>{row.status}</span></td>
              <td class="date">{formatDate(row.publishedAt ?? row.createdAt)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    ) : (
      <p class="empty">No posts yet. Create your first above.</p>
    )}
  </div>
</Page>

<style>
  .write-dash {
    max-width: 52rem;
    margin-inline: auto;
  }

  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  h1 {
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    letter-spacing: -0.02em;
  }

  .actions {
    display: flex;
    gap: var(--space-3);
  }

  .btn-new {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-5);
    background-color: var(--color-accent);
    color: var(--color-text-on-accent);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    text-decoration: none;
    transition: background-color var(--transition);
    white-space: nowrap;
  }

  .btn-new:hover {
    background-color: var(--color-accent-hover);
  }

  .btn-new--ghost {
    background-color: transparent;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }

  .btn-new--ghost:hover {
    background-color: var(--color-surface-2);
    color: var(--color-text-primary);
  }

  /* ── Stats ── */
  .stats {
    display: flex;
    gap: var(--space-6);
    padding: var(--space-6);
    background-color: var(--color-surface-1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-8);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .stat-value {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ── Table ── */
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  thead th {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--color-border);
  }

  tbody tr {
    border-bottom: 1px solid var(--color-border);
    transition: background-color var(--transition);
  }

  tbody tr:last-child {
    border-bottom: none;
  }

  tbody tr:hover {
    background-color: var(--color-surface-1);
  }

  tbody td {
    padding: var(--space-4);
    vertical-align: middle;
    color: var(--color-text-primary);
  }

  tbody td:first-child {
    max-width: 24rem;
  }

  tbody td a {
    color: var(--color-text-primary);
    text-decoration: none;
    font-weight: var(--weight-medium);
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  tbody td a:hover {
    color: var(--color-text-link);
  }

  .preview {
    color: var(--color-text-secondary);
    font-weight: var(--weight-normal);
    font-style: italic;
  }

  .date {
    color: var(--color-text-tertiary);
    white-space: nowrap;
  }

  /* ── Pills ── */
  .pill {
    display: inline-block;
    padding: 0.15em var(--space-3);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: capitalize;
    background-color: var(--color-surface-2);
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .pill-draft {
    background-color: oklch(90% 0.03 250);
    color: oklch(30% 0.08 250);
  }

  .pill-published {
    background-color: oklch(90% 0.04 145);
    color: oklch(30% 0.10 145);
  }

  .pill-article {
    background-color: var(--color-surface-2);
    color: var(--color-text-secondary);
  }

  .pill-note {
    background-color: oklch(92% 0.02 60);
    color: oklch(35% 0.06 60);
  }

  .empty {
    color: var(--color-text-tertiary);
    font-style: italic;
    padding: var(--space-8) 0;
    text-align: center;
  }

  .stats-tool-link {
    margin-left: auto;
    align-self: flex-end;
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    white-space: nowrap;
  }

  .stats-tool-link:hover {
    color: var(--color-text-secondary);
  }
</style>
