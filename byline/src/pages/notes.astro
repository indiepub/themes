---
import Page from '../layouts/Page.astro';
import NoteComposer from '../components/NoteComposer.astro';
import Markdown from '@indiepub/astro/components/Markdown';
import { Icon } from 'astro-icon/components';

if (!Astro.locals.indiepub) {
  return new Response('Service unavailable', { status: 503 });
}

const { content } = Astro.locals.indiepub;
const memberTier = Astro.locals.member?.tier ?? null;

const PER_PAGE = 20;

const pageParam = parseInt(Astro.url.searchParams.get('page') ?? '1', 10);
const page = Number.isFinite(pageParam) && pageParam > 0 ? pageParam : 1;
const offset = (page - 1) * PER_PAGE;

// Fetch one extra to know whether there's a next page
const fetched = await content.getEntries('note', { memberTier, limit: PER_PAGE + 1, offset });
const hasNext = fetched.length > PER_PAGE;
const notes = hasNext ? fetched.slice(0, PER_PAGE) : fetched;
const hasPrev = page > 1;

// Pre-compute display data
interface NoteItem {
  slug: string;
  content: string;
  isoDate: string | undefined;
  date: string;
}

const noteItems: NoteItem[] = notes.map(entry => ({
  slug: entry.slug,
  content: entry.content ?? '',
  isoDate: entry.publishedAt?.toISOString(),
  date: entry.publishedAt
    ? entry.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
    : '',
}));

Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=3600');
---

<Page title="Notes">
  <div class="notes-page">
    <h1>Notes</h1>

    <NoteComposer />

    {noteItems.length === 0 && (
      <p class="text-secondary">No notes yet.</p>
    )}

    <div class="stream">
      {noteItems.map(note => (
        <article>
          {note.isoDate && (
            <header>
              <a href={`/posts/${note.slug}`}>
                <time datetime={note.isoDate}>{note.date}</time>
              </a>
            </header>
          )}
          <Markdown content={note.content} class="note-body" />
          <footer>
            <a href={`/posts/${note.slug}`} aria-label="Permalink to this note">
              <Icon name="lucide:link" aria-hidden="true" width="13" height="13" />
              Share
            </a>
          </footer>
        </article>
      ))}
    </div>

    {(hasPrev || hasNext) && (
      <nav class="pagination" aria-label="Notes pagination">
        <span>
          {hasPrev && (
            <a href={page === 2 ? '/notes' : `/notes?page=${page - 1}`}>← Newer</a>
          )}
        </span>
        <span class="page">Page {page}</span>
        <span>
          {hasNext && (
            <a href={`/notes?page=${page + 1}`}>Older →</a>
          )}
        </span>
      </nav>
    )}
  </div>
</Page>

<style>
  .notes-page {
    padding-block: var(--space-10);
    max-width: 36rem;
    margin-inline: auto;
  }

  .notes-page h1 {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    font-weight: var(--weight-bold);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-8);
  }

  .stream {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .stream article {
    background-color: var(--color-surface-1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5) var(--space-6);
  }

  .stream header {
    margin-bottom: var(--space-3);
  }

  .stream header a {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-tertiary);
    text-decoration: none;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    transition: color var(--transition);
  }

  .stream header a:hover {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .stream footer {
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .stream footer a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color var(--transition);
  }

  .stream footer a:hover {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  /* ── Pagination ── */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-10);
    margin-top: var(--space-4);
  }

  .pagination > span:last-child {
    text-align: right;
  }

  .pagination a {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition);
  }

  .pagination a:hover {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .pagination .page {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }
</style>
