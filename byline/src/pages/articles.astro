---
import Page from '../layouts/Page.astro';
import { setCollectionCacheHeaders } from '../lib/cache';

if (!Astro.locals.indiepub) {
  return new Response('Service unavailable', { status: 503 });
}

const { content } = Astro.locals.indiepub;
const memberTier = Astro.locals.member?.tier ?? null;

const articles = await content.getEntries('article', { memberTier, limit: 500 });

function fmtShort(d: Date | undefined) {
  if (!d) return '';
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

// Group by year, pre-computed to avoid block-body lambdas in JSX
interface ArticleRow {
  isoDate: string | undefined;
  date: string;
  slug: string;
  title: string;
}

interface YearGroup {
  year: number;
  rows: ArticleRow[];
}

const byYear: Record<number, ArticleRow[]> = {};
for (const entry of articles) {
  const pubDate = entry.publishedAt ?? entry.createdAt;
  const year = pubDate ? pubDate.getFullYear() : new Date().getFullYear();
  (byYear[year] ??= []).push({
    isoDate: pubDate?.toISOString(),
    date: fmtShort(pubDate),
    slug: entry.slug,
    title: entry.name ?? 'Untitled',
  });
}

const yearGroups: YearGroup[] = Object.keys(byYear)
  .map(Number)
  .sort((a, b) => b - a)
  .map(year => ({ year, rows: byYear[year]! }));

setCollectionCacheHeaders(Astro.response, !!Astro.locals.isAdmin, articles);
---

<Page title="Articles">
  <div class="articles-page">
    <h1>Articles</h1>

    {articles.length === 0 && (
      <p class="text-secondary">No articles yet.</p>
    )}

    {yearGroups.map(group => (
      <section aria-labelledby={`year-${group.year}`}>
        <h2 id={`year-${group.year}`}>{group.year}</h2>
        <ol>
          {group.rows.map(row => (
            <li>
              {row.date
                ? <time datetime={row.isoDate}>{row.date}</time>
                : <span>—</span>
              }
              <a href={`/posts/${row.slug}`}>{row.title}</a>
            </li>
          ))}
        </ol>
      </section>
    ))}
  </div>
</Page>

<style>
  .articles-page {
    padding-block: var(--space-10);
  }

  .articles-page h1 {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    font-weight: var(--weight-bold);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-12);
  }

  .articles-page section {
    margin-bottom: var(--space-10);
  }

  .articles-page h2 {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .articles-page ol {
    list-style: none;
    padding: 0;
  }

  .articles-page li {
    display: grid;
    grid-template-columns: 5ch 1fr;
    gap: var(--space-4);
    align-items: baseline;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .articles-page li:last-child {
    border-bottom: none;
  }

  .articles-page time,
  .articles-page li > span {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    font-family: var(--font-sans);
    white-space: nowrap;
  }

  .articles-page a {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--transition);
    line-height: var(--leading-snug);
  }

  .articles-page a:hover {
    color: var(--color-text-link);
    text-decoration: none;
  }
</style>
