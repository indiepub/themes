---
import Page from '../../layouts/Page.astro';
import Markdown from '@indiepub/astro/components/Markdown.astro';
import { Icon } from 'astro-icon/components';
import { setEntryCacheHeaders } from '../../lib/cache';

if (!Astro.locals.indiepub) {
  return new Response('Service unavailable', { status: 503 });
}

const { slug } = Astro.params;
if (!slug) return new Response('Not found', { status: 404 });

const { content, config } = Astro.locals.indiepub;

const entry = await content.getEntry(slug);
if (!entry) return new Response('Not found', { status: 404 });

if (entry.visibility === 'private') return new Response('Not found', { status: 404 });

if (entry.visibility === 'members' && !Astro.locals.member) {
  return Response.redirect(
    new URL(`/login?next=${encodeURIComponent(Astro.url.pathname)}`, Astro.request.url),
    302,
  );
}

const pageTitle = entry.name ?? (entry.content
  ? entry.content.replace(/<[^>]*>/g, '').slice(0, 60)
  : 'Post');
const pageDescription = entry.summary ?? undefined;
const ogImage = `/og/${entry.slug}`;

const publishedDate = entry.publishedAt
  ? new Date(entry.publishedAt).toLocaleDateString('en-US', {
      year: 'numeric', month: 'long', day: 'numeric',
    })
  : null;

const showSubscribeCta =
  (config.subscriptions?.enabled ?? false) && !Astro.locals.member;

setEntryCacheHeaders(Astro.response, entry);
---

<Page title={pageTitle} description={pageDescription} ogImage={ogImage} narrow>
  {entry.type === 'note' ? (
    /* ── Note card UI ── */
    <div class="note-wrap">
      <a href="/notes" class="back">← Notes</a>
      <article class="h-entry">
        {publishedDate && (
          <header>
            <time class="dt-published" datetime={entry.publishedAt?.toISOString()}>
              {publishedDate}
            </time>
          </header>
        )}

        {entry.verb && entry.objectName && (
          <div class="verb-callout">
            <span class="verb-emoji">
              {entry.verb === 'watch' ? '📺' : entry.verb === 'read' ? '📚' : entry.verb === 'listen' ? '🎧' : entry.verb === 'play' ? '🎮' : ''}
            </span>
            <span>
              {entry.verb === 'watch' ? 'Watched' : entry.verb === 'read' ? 'Read' : entry.verb === 'listen' ? 'Listened to' : entry.verb === 'play' ? 'Played' : entry.verb}
              {' '}
              {entry.objectUrl ? (
                <a href={entry.objectUrl} rel="noopener" target="_blank">
                  {entry.objectName}
                  <Icon name="lucide:external-link" aria-hidden="true" width="13" height="13" />
                </a>
              ) : (
                <strong>{entry.objectName}</strong>
              )}
            </span>
          </div>
        )}
        {entry.rating != null && entry.rating > 0 && (
          <div class="verb-rating" aria-label={`Rating: ${entry.rating} out of 5`}>
            {[1,2,3,4,5].map(n => (
              <span>{n <= entry.rating! ? '★' : '☆'}</span>
            ))}
          </div>
        )}

        {entry.content && (
          <Markdown content={entry.content} class="note-body e-content" />
        )}

        <footer>
          <a href={Astro.url.href} aria-label="Permalink to this note">
            <Icon name="lucide:link" aria-hidden="true" width="13" height="13" />
            Share
          </a>
        </footer>
      </article>
    </div>
  ) : (
    /* ── Article UI ── */
    <article class="article h-entry">
      <header>
        <a href="/" class="back">← Back</a>

        {entry.name && (
          <h1 class="p-name">{entry.name}</h1>
        )}

        <div class="byline">
          {publishedDate && (
            <time class="dt-published" datetime={entry.publishedAt?.toISOString()}>
              {publishedDate}
            </time>
          )}
        </div>

        {entry.summary && (
          <p class="deck p-summary">{entry.summary}</p>
        )}
      </header>

      {entry.content && (
        <Markdown content={entry.content} class="prose e-content" />
      )}
    </article>
  )}

  {showSubscribeCta && (
    <aside>
      <p>Enjoyed this?</p>
      <h2>Subscribe to {config.title ?? 'this publication'}</h2>
      <p>New posts delivered to your inbox. No spam, unsubscribe any time.</p>
      <form method="POST" action="/subscribe">
        <input
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder="your@email.com"
        />
        <button type="submit">Subscribe</button>
      </form>
    </aside>
  )}
</Page>

<style>
  /* ── Shared back link ── */
  .back {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    text-decoration: none;
    margin-bottom: var(--space-4);
    transition: color var(--transition);
  }

  .back:hover {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  /* ── Note card ── */
  .note-wrap {
    padding-block-end: var(--space-10);
  }

  .note-wrap article {
    background-color: var(--color-surface-1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5) var(--space-6);
  }

  .note-wrap header {
    margin-bottom: var(--space-3);
  }

  .note-wrap time {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-tertiary);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .note-wrap footer {
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .note-wrap footer a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color var(--transition);
  }

  .note-wrap footer a:hover {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  /* ── Verb callout ── */
  .verb-callout {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-surface-2, var(--color-surface));
    border-radius: var(--radius-md);
    margin-bottom: var(--space-3);
    font-size: var(--text-sm);
  }

  .verb-emoji {
    font-size: var(--text-lg);
    flex-shrink: 0;
  }

  .verb-callout a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .verb-callout a:hover {
    color: var(--color-accent);
  }

  .verb-rating {
    display: flex;
    gap: 0.125rem;
    font-size: var(--text-base);
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  /* ── Article ── */
  .article {
    padding-block-end: var(--space-10);
  }

  .article header {
    margin-bottom: var(--space-10);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }

  .article h1 {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: var(--weight-bold);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-top: var(--space-4);
    margin-bottom: var(--space-5);
  }

  .byline {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-5);
  }

  .deck {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    font-style: italic;
  }

  /* ── End-of-article subscribe CTA ── */
  aside {
    margin-top: var(--space-16);
    padding-top: var(--space-10);
    border-top: 2px solid var(--color-accent);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  aside p:first-child {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  }

  aside h2 {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-snug);
    letter-spacing: -0.01em;
    margin: 0;
  }

  aside h2 + p {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  aside form {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-top: var(--space-2);
  }

  aside input {
    flex: 1;
    min-width: 14rem;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-base);
    font-family: var(--font-sans);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    background-color: var(--color-surface-1);
    color: var(--color-text-primary);
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  aside input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-muted);
  }

  aside button {
    padding: var(--space-3) var(--space-6);
    background-color: var(--color-accent);
    color: var(--color-text-on-accent);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    font-family: var(--font-sans);
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: background-color var(--transition);
    white-space: nowrap;
  }

  aside button:hover {
    background-color: var(--color-accent-hover);
  }
</style>
