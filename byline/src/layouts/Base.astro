---
import '../styles/global.css';

interface Props {
  title?: string | undefined;
  description?: string | undefined;
  canonicalUrl?: string | undefined;
  ogImage?: string | undefined;
  /** data-palette attribute injected on <html> — set by Page.astro from site_settings */
  palette?: string | undefined;
}

const config = Astro.locals.indiepub?.config;
const siteTitle = config?.title ?? 'My Publication';
const accentColor  = Astro.locals.indiepub?.accentColor ?? null;
const themePalette = Astro.locals.indiepub?.themePalette ?? null;

// Inject accent color as inline CSS custom properties on :root.
// This reliably overrides palette presets in the stylesheet cascade.
const accentStyle = accentColor ? [
  `--color-accent: ${accentColor}`,
  `--color-accent-hover: color-mix(in oklch, ${accentColor} 80%, black)`,
  `--color-accent-muted: color-mix(in oklch, ${accentColor} 18%, white)`,
  `--color-text-link: ${accentColor}`,
  `--color-text-link-hover: color-mix(in oklch, ${accentColor} 80%, black)`,
  `--color-text-on-accent: color-mix(in oklch, ${accentColor} 8%, white)`,
  `--color-rule: ${accentColor}`,
].join('; ') : undefined;

const { title, description, canonicalUrl, ogImage, palette } = Astro.props;

const pageTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const pageDescription = description ?? config?.description ?? '';
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;
---

<!doctype html>
<html lang={config?.language ?? 'en'} data-palette={palette ?? themePalette ?? undefined} style={accentStyle}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {pageDescription && <meta name="description" content={pageDescription} />}
    <link rel="canonical" href={canonical} />

    <!-- Lora serif — editorial workhorse -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap"
    />

    {Astro.locals.indiepub?.faviconUrl && (
      <link rel="icon" href={Astro.locals.indiepub.faviconUrl} />
    )}

    <!-- Open Graph -->
    <meta property="og:title"       content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:type"        content="website" />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site ?? Astro.url.origin).href} />}

    <!-- Twitter / X card -->
    <meta name="twitter:card"        content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title"       content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site ?? Astro.url.origin).href} />}

    <!-- IndieWeb endpoint discovery -->
    <link rel="micropub"    href="/micropub" />
    <link rel="webmention"  href="/.well-known/webmention" />

    <!-- Feed discovery -->
    <link rel="alternate" type="application/rss+xml"  title={`${siteTitle} (RSS)`}       href="/feed.xml" />
    <link rel="alternate" type="application/atom+xml" title={`${siteTitle} (Atom)`}      href="/feed.atom" />
    <link rel="alternate" type="application/feed+json" title={`${siteTitle} (JSON Feed)`} href="/feed.json" />

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
