---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string | undefined;
  description?: string | undefined;
  canonicalUrl?: string | undefined;
  ogImage?: string | undefined;
  /** Remove horizontal padding for full-bleed sections (homepage hero) */
  fullBleed?: boolean | undefined;
  /** Narrow the content column for focused reading (article detail) */
  narrow?: boolean | undefined;
}

const { title, description, canonicalUrl, ogImage, fullBleed = false, narrow = false } = Astro.props;
---

<Base title={title} description={description} canonicalUrl={canonicalUrl} ogImage={ogImage}>
  <div>
    <Header />
    <main class:list={[{ 'main--full-bleed': fullBleed, 'main--narrow': narrow }]}>
      <slot />
    </main>
    <Footer />
  </div>
</Base>

<style>
  div {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
    width: 100%;
    max-width: var(--max-width-content);
    margin-inline: auto;
    padding: var(--space-8) var(--space-4);
  }

  .main--full-bleed {
    max-width: none;
    padding-inline: 0;
  }

  .main--narrow {
    max-width: var(--max-width-prose);
  }

  @media (min-width: 640px) {
    main {
      padding-inline: var(--space-6);
    }
  }

  @media (min-width: 768px) {
    main {
      padding: var(--space-16) var(--space-8);
    }

    .main--full-bleed {
      padding-inline: 0;
    }
  }
</style>
