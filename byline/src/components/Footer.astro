---
import { Icon } from 'astro-icon/components';

const config = Astro.locals.indiepub?.config;
const siteTitle = config?.title ?? 'My Publication';

const author = Astro.locals.indiepub
  ? await Astro.locals.indiepub.content.getAuthor()
  : null;

const socialLinks = author?.socialLinks ?? [];

const year = new Date().getFullYear();
---

<footer>
  <div>
    <span class="font-serif">{siteTitle}</span>

    <nav aria-label="Footer navigation">
      <a href="/archive">Archive</a>
      <a href="/about">About</a>
      <a href="/subscribe">Subscribe</a>
    </nav>

    {socialLinks.length > 0 && (
      <nav aria-label="Social links">
        {socialLinks.map(link => (
          <a
            href={link.url}
            rel="me noopener"
            target="_blank"
            aria-label={link.label}
          >
            <Icon name={`social/${link.icon}`} aria-hidden="true" width="16" height="16" />
          </a>
        ))}
      </nav>
    )}

    <p class="text-xs text-secondary">
      &copy; {year} {author?.name ?? siteTitle} &middot;
      Powered by <a href="https://indiepub.dev" target="_blank" rel="noopener">IndiePub</a>
    </p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    background-color: var(--color-bg-alt);
    padding: var(--space-12) var(--space-6);
    margin-top: var(--space-16);
  }

  footer > div {
    max-width: var(--max-width-site);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    text-align: center;
  }

  footer > div > span {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
  }

  nav[aria-label="Footer navigation"] {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
    justify-content: center;
  }

  nav[aria-label="Footer navigation"] a {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition);
  }

  nav[aria-label="Footer navigation"] a:hover {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  nav[aria-label="Social links"] {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
  }

  nav[aria-label="Social links"] a {
    display: inline-flex;
    align-items: center;
    color: var(--color-text-tertiary);
    transition: color var(--transition);
  }

  nav[aria-label="Social links"] a:hover {
    color: var(--color-text-secondary);
  }

  p {
    color: var(--color-text-tertiary);
  }

  p a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  p a:hover {
    color: var(--color-text-secondary);
  }
</style>
