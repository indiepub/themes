---
import { Icon } from 'astro-icon/components';
import type { Entry, Interaction, InteractionCounts, WebMention } from '@indiepub/types';
import Markdown from '@indiepub/astro/components/Markdown.astro';
import PhotoCarousel from '@indiepub/astro/components/PhotoCarousel.astro';
import TagList from './TagList.astro';
import HCard from './HCard.astro';
import VerbCallout from './VerbCallout.astro';
import StarRating from './StarRating.astro';
import Responses from './Responses.astro';
import { formatDate, isoDate, hostname } from '../lib/format.ts';

interface Props {
  entry: Entry;
  webmentions: WebMention[];
  interactions: Interaction[];
  counts: InteractionCounts;
}

const { entry, webmentions, interactions, counts } = Astro.props;

// Merge interactions and webmentions into unified response items
type ResponseItem = {
  type: 'like' | 'repost' | 'comment';
  authorName?: string | undefined;
  authorUrl?: string | undefined;
  authorPhoto?: string | undefined;
  content?: string | undefined;
  sourceUrl: string;
  sourceLabel: string;
};

const allResponses: ResponseItem[] = [];

for (const ix of interactions) {
  if (ix.type !== 'like' && ix.type !== 'repost' && ix.type !== 'comment') continue;
  allResponses.push({
    type: ix.type,
    authorName: ix.authorName,
    authorUrl: ix.authorUrl,
    authorPhoto: ix.authorPhoto,
    content: ix.content,
    sourceUrl: ix.externalUrl ?? ix.authorUrl ?? '#',
    sourceLabel: ix.source === 'bluesky' ? 'Bluesky' : ix.source === 'mastodon' ? 'Mastodon' : ix.source,
  });
}

for (const wm of webmentions) {
  const wmType = wm.type === 'reply' || wm.type === 'mention' ? 'comment' : wm.type === 'like' ? 'like' : wm.type === 'repost' ? 'repost' : null;
  if (!wmType) continue;
  allResponses.push({
    type: wmType,
    authorName: wm.authorName,
    authorUrl: wm.authorUrl,
    authorPhoto: wm.authorPhoto,
    content: wm.content,
    sourceUrl: wm.source,
    sourceLabel: hostname(wm.source),
  });
}

const pubDate = entry.publishedAt ?? entry.createdAt;
const config = Astro.locals.indiepub?.config;

const attachments = entry.attachments?.length
  ? entry.attachments
  : entry.photo
    ? [{ id: '', url: entry.photo, contentType: 'image/*', displayOrder: 0 }]
    : [];
---

<article class="h-entry">
  <header>
    {entry.name && (
      <h1 class="p-name">{entry.name}</h1>
    )}
    <div class="meta">
      <a href={`/posts/${entry.slug}`} class="u-url permalink">
        <time class="dt-published" datetime={isoDate(pubDate)}>
          {formatDate(pubDate)}
        </time>
      </a>
      {entry.updatedAt && entry.updatedAt > pubDate && (
        <span class="text-sm text-secondary">
          Updated <time class="dt-updated" datetime={isoDate(entry.updatedAt)}>{formatDate(entry.updatedAt)}</time>
        </span>
      )}
    </div>

    {entry.verb && entry.objectName && (
      <VerbCallout verb={entry.verb} objectName={entry.objectName} objectUrl={entry.objectUrl} size="large" />
    )}
    {entry.rating != null && entry.rating > 0 && (
      <StarRating rating={entry.rating} size="xl" />
    )}

    {entry.inReplyTo && (
      <p class="reply-to">
        <Icon name="corner-down-right" aria-hidden="true" />
        <span>in reply to </span>
        <a href={entry.inReplyTo} class="u-in-reply-to" rel="noopener" target="_blank">{hostname(entry.inReplyTo)}</a>
      </p>
    )}
  </header>

  {attachments.length > 0 && (
    <PhotoCarousel
      attachments={attachments}
      fallbackAlt={entry.summary ?? entry.name ?? ''}
      sizes="(min-width: 768px) 65ch, 100vw"
      class="entry-media"
    />
  )}

  {entry.content && (
    <Markdown content={entry.content} class="e-content entry-detail__content prose" />
  )}

  <footer>
    <TagList tags={entry.tags} />

    {entry.syndicationUrls && entry.syndicationUrls.length > 0 && (
      <div class="syndication">
        <p class="text-sm text-secondary">Syndicated to:</p>
        <ul>
          {entry.syndicationUrls.map((url: string) => (
            <li>
              <a href={url} class="u-syndication" rel="syndication noopener" target="_blank">
                {hostname(url)}
                <Icon name="external-link" aria-hidden="true" />
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {(counts.likes > 0 || counts.comments > 0 || counts.reposts > 0) && (
      <div class="counts">
        {counts.likes > 0 && (
          <span>
            <Icon name="heart" aria-hidden="true" />
            {counts.likes} {counts.likes === 1 ? 'like' : 'likes'}
          </span>
        )}
        {counts.reposts > 0 && (
          <span>
            <Icon name="repeat-2" aria-hidden="true" />
            {counts.reposts} {counts.reposts === 1 ? 'repost' : 'reposts'}
          </span>
        )}
        {counts.comments > 0 && (
          <span>
            <Icon name="message-square" aria-hidden="true" />
            {counts.comments} {counts.comments === 1 ? 'comment' : 'comments'}
          </span>
        )}
      </div>
    )}

    {entry.author && (
      <HCard author={entry.author} config={config} variant="compact" />
    )}
  </footer>
</article>

{allResponses.length > 0 && (
  <Responses responses={allResponses} />
)}

<style>
  article {
    max-width: var(--max-width-content);
  }

  header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  h1 {
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
  }

  .meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .permalink {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    text-decoration: none;
  }

  .permalink:hover {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .reply-to {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .reply-to :global(svg) {
    width: 0.875rem;
    height: 0.875rem;
    color: var(--color-text-tertiary);
    flex-shrink: 0;
  }

  .entry-media {
    margin-bottom: var(--space-6);
    border-radius: var(--radius-lg);
  }

  footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .syndication ul {
    list-style: none;
    padding: 0;
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .syndication a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
  }

  .syndication :global(svg) {
    width: 0.75rem;
    height: 0.75rem;
  }

  .counts {
    display: flex;
    gap: var(--space-4);
  }

  .counts > span {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .counts :global(svg) {
    width: 1rem;
    height: 1rem;
  }
</style>
