---
// Pure template component — no props needed
---

<div class="composer__toolbar">
  <button type="button" class="composer__tool" id="tool-bold" title="Bold"><strong>B</strong></button>
  <button type="button" class="composer__tool" id="tool-italic" title="Italic"><em>I</em></button>
  <button type="button" class="composer__tool" id="tool-link" title="Link">🔗</button>
  <div class="composer__link-prompt" id="link-prompt" hidden>
    <input type="url" id="link-url-input" class="composer__url-input" placeholder="https://…" />
    <button type="button" id="link-insert-btn" class="composer__tool">Insert</button>
  </div>
  <div class="composer__toolbar-right">
    <button type="button" class="composer__preview-btn" id="preview-btn">Preview</button>
  </div>
</div>
