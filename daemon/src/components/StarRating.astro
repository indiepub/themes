---
interface Props {
  rating: number;
  /** Font size — defaults to 'base' for cards, 'xl' for detail views */
  size?: 'base' | 'xl';
}

const { rating, size = 'base' } = Astro.props;
---

<span class={`stars--${size}`} aria-label={`Rating: ${rating} out of 5`}>
  {[1,2,3,4,5].map(n => (
    <span data-filled={n <= rating ? '' : undefined} aria-hidden="true">{n <= rating ? '★' : '☆'}</span>
  ))}
</span>

<style>
  .stars--base {
    display: flex;
    gap: 0.125rem;
    font-size: var(--text-base);
  }

  .stars--xl {
    display: flex;
    gap: 0.125rem;
    font-size: var(--text-xl);
  }

  span span {
    color: var(--color-border);
  }

  span span[data-filled] {
    color: var(--color-text-link, var(--color-accent));
  }
</style>
