---
import FeedLinks from './FeedLinks.astro';
import { Icon } from 'astro-icon/components';

const currentPath = Astro.url.pathname;
const subscriptionsEnabled = Astro.locals.indiepub?.config.subscriptions?.enabled ?? false;

const sections = [
  { href: '/notes',     label: 'Notes',     icon: 'message-circle' },
  { href: '/articles',  label: 'Articles',  icon: 'file-text' },
  { href: '/photos',    label: 'Photos',    icon: 'image' },
  { href: '/bookmarks', label: 'Bookmarks', icon: 'bookmark' },
];
---

<div class="sidebar">
  <nav class="sidebar-section" aria-label="Browse content">
    <p class="sidebar-heading">Browse</p>
    <ul class="sidebar-nav">
      {sections.map(({ href, label, icon }) => (
        <li>
          <a
            href={href}
            class="sidebar-nav__link"
            aria-current={currentPath.startsWith(href) ? 'page' : undefined}
          >
            <Icon name={icon} aria-hidden="true" />
            <span>{label}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>

  {subscriptionsEnabled && (
    <div class="sidebar-section">
      <a href="/subscribe" class="subscribe-cta">
        <Icon name="mail" aria-hidden="true" />
        Subscribe via email
      </a>
    </div>
  )}

  <div class="sidebar-section">
    <FeedLinks />
  </div>
</div>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .sidebar-heading {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-2);
  }

  .sidebar-nav {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .sidebar-nav__link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: background-color var(--transition), color var(--transition);
  }

  .sidebar-nav__link:hover,
  .sidebar-nav__link[aria-current="page"] {
    background-color: var(--color-brand-muted);
    color: var(--color-text-link);
    text-decoration: none;
  }

  .sidebar-nav__link svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .subscribe-cta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    background: var(--color-brand-muted);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-link);
    text-decoration: none;
    transition: background var(--transition);
  }

  .subscribe-cta:hover {
    background: var(--color-brand-muted);
    filter: brightness(0.95);
    text-decoration: none;
  }

  .subscribe-cta svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }
</style>
