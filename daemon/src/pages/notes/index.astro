---
import Page from '../../layouts/Page.astro';
import EntryCard from '../../components/EntryCard.astro';
import NoteComposer from '../../components/NoteComposer.astro';
import { setCollectionCacheHeaders } from '../../lib/cache';

if (!Astro.locals.indiepub) {
  return new Response('Service unavailable', { status: 503 });
}

const { content } = Astro.locals.indiepub;
const memberTier = Astro.locals.member?.tier ?? null;
const notes = await content.getEntries(['note', 'watch', 'read', 'listen', 'play'], { memberTier, limit: 30 });
const countsMap = await content.getBatchInteractionCounts(notes.map(e => e.id));

setCollectionCacheHeaders(Astro.response, !!Astro.locals.isAdmin, notes);
---

<Page title="Notes">
  <div class="page-header">
    <h1>Notes</h1>
    <p class="text-secondary">Short posts, thoughts, and replies.</p>
  </div>

  <NoteComposer />

  {notes.length > 0 ? (
    <div class="h-feed entry-feed" aria-label="Notes feed">
      {notes.map(entry => (
        <EntryCard entry={entry} counts={countsMap.get(entry.id)} />
      ))}
    </div>
  ) : (
    <p class="text-secondary">No notes yet.</p>
  )}
</Page>

<style>
  .page-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .entry-feed {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
</style>
