---
import Page from '../layouts/Page.astro';

if (!Astro.locals.indiepub) {
  return new Response('Service unavailable', { status: 503 });
}

const { config } = Astro.locals.indiepub;

if (!config.subscriptions?.enabled) {
  return new Response('Not Found', { status: 404 });
}

// Already logged in — redirect home
if (Astro.locals.member) {
  return Response.redirect(new URL('/', Astro.request.url), 303);
}

const params = Astro.url.searchParams;
const sent = params.get('sent') === '1';
const error = params.get('error');
const next = params.get('next') ?? '/';

const errorMessages: Record<string, string> = {
  invalid: 'That link is invalid. Please request a new one.',
  expired: 'That link has expired. Please request a new one.',
  notfound: 'We couldn\'t find an active subscription for that email.',
  config: 'Login is temporarily unavailable. Please try again later.',
};

const errorMessage = error ? (errorMessages[error] ?? 'Something went wrong. Please try again.') : null;
---

<Page title="Member Login" hideSidebar>
  <div class="login-page">
    <div class="login-page__header">
      <h1>Member Login</h1>
      <p>Enter your email address and we'll send you a sign-in link.</p>
    </div>

    {sent ? (
      <div class="login-notice login-notice--success" role="status">
        <span aria-hidden="true">✓</span>
        <p>Check your inbox — if that email is registered, we've sent a sign-in link. It expires in 15 minutes.</p>
      </div>
    ) : (
      <>
        {errorMessage && (
          <div class="login-notice login-notice--error" role="alert">
            <span aria-hidden="true">✗</span>
            <p>{errorMessage}</p>
          </div>
        )}

        <form class="login-form" method="post" action="/auth/login">
          <input type="hidden" name="next" value={next} />
          <div class="login-form__field">
            <label for="login-email">Email address</label>
            <input
              type="email"
              id="login-email"
              name="email"
              placeholder="you@example.com"
              autocomplete="email"
              required
              autofocus
            />
          </div>
          <button type="submit" class="login-form__btn">Send sign-in link</button>
        </form>

        <p class="login-page__hint">
          Not a subscriber yet? <a href="/subscribe">Subscribe for free</a>
        </p>
      </>
    )}
  </div>
</Page>

<style>
  .login-page {
    max-width: 24rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .login-page__header h1 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-3);
  }

  .login-page__header p {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .login-notice {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .login-notice--success {
    background: color-mix(in oklch, var(--color-success) 12%, transparent);
    border: 1px solid color-mix(in oklch, var(--color-success) 30%, transparent);
    color: var(--color-success);
  }

  .login-notice--error {
    background: color-mix(in oklch, var(--color-error, #dc2626) 10%, transparent);
    border: 1px solid color-mix(in oklch, var(--color-error, #dc2626) 25%, transparent);
    color: var(--color-error, #dc2626);
  }

  .login-notice p {
    margin: 0;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .login-form__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  label {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
  }

  input[type="email"] {
    width: 100%;
    padding: var(--space-2) var(--space-3);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-family: inherit;
    color: var(--color-text-primary);
    transition: border-color var(--transition);
  }

  input[type="email"]:focus {
    outline: none;
    border-color: var(--color-brand);
  }

  .login-form__btn {
    align-self: flex-start;
    padding: var(--space-2) var(--space-5);
    background: var(--color-brand);
    color: var(--color-text-on-brand);
    border: none;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    font-family: inherit;
    cursor: pointer;
    transition: background var(--transition);
  }

  .login-form__btn:hover {
    background: var(--color-text-link-hover);
  }

  .login-page__hint {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .login-page__hint a {
    color: var(--color-text-link);
    text-decoration: underline;
  }
</style>
